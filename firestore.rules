rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Phase 0: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Phase 4: Entity Validation
    function isValidDiaryEntry(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.dateId is string && data.dateId.size() <= 10 &&
             data.years is map && data.years.size() <= 150 && 
             (data.get('images', null) == null || (data.images is map && data.images.size() <= 150)) &&
             data.updatedAt == request.time;
    }

    function isValidCareerProfile(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             (data.get('appointmentDate', null) == null || (data.appointmentDate is string && data.appointmentDate.size() <= 20)) &&
             (data.get('promotions', null) == null || (data.promotions is list && data.promotions.size() <= 100)) &&
             (data.get('assignments', null) == null || (data.assignments is list && data.assignments.size() <= 500)) &&
             data.updatedAt == request.time;
    }

    // Rule for diary entries
    match /users/{userId}/entries/{dateId} {
      allow get, list: if isOwner(userId);
      
      allow create: if isOwner(userId) && 
                      isValidId(dateId) && 
                      isValidDiaryEntry(incoming()) &&
                      incoming().keys().hasAll(['userId', 'dateId', 'years', 'updatedAt']) &&
                      incoming().keys().size() >= 4;

      allow update: if isOwner(userId) && 
                      isValidDiaryEntry(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().dateId == existing().dateId &&
                      (
                        // Action: Update content or images
                        incoming().diff(existing()).affectedKeys().hasAny(['years', 'images', 'updatedAt']) &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['years', 'images', 'updatedAt'])
                      );

      allow delete: if isOwner(userId);
    }

    // Rule for career profile
    match /users/{userId}/career/profile {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidCareerProfile(incoming());
      allow update: if isOwner(userId) && 
                      isValidCareerProfile(incoming()) &&
                      incoming().userId == existing().userId &&
                      (
                        // Action: Update career details
                        incoming().diff(existing()).affectedKeys().hasAny(['appointmentDate', 'promotions', 'assignments', 'updatedAt']) &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['appointmentDate', 'promotions', 'assignments', 'updatedAt'])
                      );
      allow delete: if isOwner(userId);
    }
  }
}
